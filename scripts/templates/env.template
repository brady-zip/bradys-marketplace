# mem0-brady config — single source of truth for the MCP server (launchd) AND
# the SessionStart/Stop hooks. Rendered by /mem0-brady:setup. chmod 600.
# Do not commit. Edit values here and restart the launchd agents + Claude session.

# --- LLM (OpenAI) ---
# Mem0 always uses an LLM to extract facts from a conversation, no matter which
# embedding/reranking provider you pick below. ZeroEntropy does not offer an LLM,
# so an OpenAI key is required either way.
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=gpt-4o-mini

# --- Your OpenAI key (LLM fact extraction; also the embedder when EMBED_PROVIDER=openai) ---
OPENAI_API_KEY=__OPENAI_API_KEY__

# --- Embedder -----------------------------------------------------------------
# openai      -> text-embedding-3-small (1536 dims), billed to OPENAI_API_KEY
# zeroentropy -> zembed-1 (2560 dims, Matryoshka), billed to ZEROENTROPY_API_KEY
# The collection's vector size is fixed at creation, so switching providers (and
# therefore MEM0_EMBED_DIMS) needs a fresh collection — see the README.
MEM0_EMBED_PROVIDER=__EMBED_PROVIDER__
MEM0_EMBED_MODEL=__EMBED_MODEL__
MEM0_EMBED_DIMS=__EMBED_DIMS__

# --- Reranker (optional; reorders recall hits before they reach the model) ----
# Empty disables reranking (the OpenAI path). zeroentropy -> zero_entropy / zerank-1.
MEM0_RERANK_PROVIDER=__RERANK_PROVIDER__
MEM0_RERANK_MODEL=__RERANK_MODEL__

# --- ZeroEntropy key (zembed-1 embedder + zerank reranker; empty for OpenAI) ---
# The ZeroEntropy SDK reads ZEROENTROPY_API_KEY; Mem0's reranker wrapper reads
# ZERO_ENTROPY_API_KEY. Both are set to the same value to avoid that mismatch.
ZEROENTROPY_API_KEY=__ZEROENTROPY_API_KEY__
ZERO_ENTROPY_API_KEY=__ZEROENTROPY_API_KEY__

# --- Graph store: off (no Neo4j) ---
MEM0_ENABLE_GRAPH=false

# --- mem0 MCP server (port :8788; the single shared store for Claude + Hal) ---
# MEM0_USER_ID is the ONE shared namespace every actor (B, Claude, Hal) reads and
# writes, so memories cross-query. Domain is partitioned by app_id (evergreen /
# general / hal-ops), set per-call (tools) or per-session (hooks), not here.
MEM0_TRANSPORT=streamable-http
MEM0_HOST=127.0.0.1
MEM0_PORT=8788
MEM0_COLLECTION=mem0_brady
MEM0_USER_ID=shared-bch

# --- Vector store: native local Qdrant SERVER (no Docker) ---
# Both the MCP server AND the hooks connect over HTTP, so the store supports
# concurrent / multi-session access. (Embedded path mode can't — it takes an
# exclusive per-process lock.) The qdrant binary runs under its own launchd
# agent on the isolated port below.
MEM0_QDRANT_URL=http://127.0.0.1:6433
