# mem0-brady config — single source of truth for the MCP server (launchd) AND
# the SessionStart/Stop hooks. Rendered by /mem0-brady:setup. chmod 600.
# Do not commit. Edit values here and restart the launchd agents + Claude session.

# --- LLM (OpenAI) ---
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=gpt-4o-mini

# --- Embedder (OpenAI) ---
MEM0_EMBED_PROVIDER=openai
MEM0_EMBED_MODEL=text-embedding-3-small
MEM0_EMBED_DIMS=1536

# --- Your OpenAI key (used by BOTH the LLM and the embedder) ---
OPENAI_API_KEY=__OPENAI_API_KEY__

# --- Graph store: off (no Neo4j) ---
MEM0_ENABLE_GRAPH=false

# --- mem0 MCP server (port :8788; the single shared store for Claude + Hal) ---
# MEM0_USER_ID is the ONE shared namespace every actor (B, Claude, Hal) reads and
# writes, so memories cross-query. Domain is partitioned by app_id (evergreen /
# general / hal-ops), set per-call (tools) or per-session (hooks), not here.
MEM0_TRANSPORT=streamable-http
MEM0_HOST=127.0.0.1
MEM0_PORT=8788
MEM0_COLLECTION=mem0_brady
MEM0_USER_ID=shared-bch

# --- Vector store: native local Qdrant SERVER (no Docker) ---
# Both the MCP server AND the hooks connect over HTTP, so the store supports
# concurrent / multi-session access. (Embedded path mode can't — it takes an
# exclusive per-process lock.) The qdrant binary runs under its own launchd
# agent on the isolated port below.
MEM0_QDRANT_URL=http://127.0.0.1:6433
